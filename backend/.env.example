# ============================================================================
# KVPL - Professional Portfolio API
# Environment Configuration Example
# ============================================================================
# Copy this file to .env and fill in your actual values

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:your_secure_password@localhost:5432/kvpl

# Or configure individual components:
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=kvpl
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ============================================================================
# FLASK CONFIGURATION
# ============================================================================

# Flask environment: development, testing, production
FLASK_ENV=development
FLASK_DEBUG=True

# Flask secret key for session management
FLASK_SECRET_KEY=your-super-secret-key-change-this

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Application host and port
APP_HOST=0.0.0.0
APP_PORT=5000

# API Base URL (for CORS, documentation links, etc.)
API_BASE_URL=http://localhost:5000

# ============================================================================
# CORS CONFIGURATION
# ============================================================================

# Allowed origins for CORS (comma-separated for multiple)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (relative to backend directory)
LOG_FILE=logs/app.log

# ============================================================================
# DOCKER CONFIGURATION (if using docker-compose)
# ============================================================================

# When using docker-compose, use the service name as host
# DATABASE_URL=postgresql://postgres:your_secure_password@db:5432/kvpl

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable/disable specific features
ENABLE_AUDIT_LOGGING=True
ENABLE_WATER_TRACKING=True
ENABLE_LABOUR_OPTIMIZATION=True
ENABLE_ROI_CALCULATIONS=True
